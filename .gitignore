# Secrets — never commit
.env
.env.*
!.env.example

# Dependencies
node_modules/
mcp/**/node_modules/

# Vendored opencode fork: SOURCE is tracked, ignore only its build output
vendor/**/node_modules/
vendor/**/dist/
vendor/**/.turbo/
vendor/opencode/.sst/

# Next.js
.next/
out/
build/
next-env.d.ts
tsconfig.tsbuildinfo

# Per-session agent workspaces (uploaded client docs + generated reports)
workspaces/
!workspaces/.gitkeep

# opencode local state
.opencode/auth.json
.opencode/cache/

# Clean-room context-manager work lives in its OWN separate (private) repo,
# not in the reporting-agent repo. The whole folder is ignored here.
# (Inside that separate repo, reference-agpl/ is itself git-ignored as the
# analyst-only AGPL source, so it is never committed anywhere.)
/dcp-rewrite/

# Logs / OS
*.log
npm-debug.log*
.DS_Store
Thumbs.db
*.lnk
