{
  "$schema": "https://opencode.ai/config.json",

  "model": "opencode-go/deepseek-v4-flash",
  "small_model": "opencode-go/deepseek-v4-flash",

  "plugin": [
    [
      "./.opencode/context-manager.js",
      {
        "dcp": {
          "models": {
            "qwen3.6:27b": {
              "hardCap": "88%",
              "nudges": {
                "lowerThreshold": "45%",
                "midSoftNudge": "62%",
                "upperThreshold": "75%",
                "maskTriggerThreshold": "45%"
              }
            },
            "deepseek-v4-flash": {
              "hardCap": "88%",
              "nudges": {
                "lowerThreshold": "45%",
                "midSoftNudge": "62%",
                "upperThreshold": "75%",
                "maskTriggerThreshold": "45%"
              }
            }
          }
        }
      }
    ]
  ],

  "provider": {
    "opencode-go": {
      "options": {
        "apiKey": "{env:OPENCODE_GO_API_KEY}"
      }
    },
    "gemma4-aws": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "Local model (AWS Ollama)",
      "options": {
        "apiKey": "{env:GEMMA_API_KEY}",
        "baseURL": "{env:GEMMA_BASE_URL}"
      },
      "models": {
        "qwen3.6-256k:latest": {
          "name": "Qwen 3.6 27B (256K)",
          "limit": {
            "context": 262144,
            "output": 8192
          }
        }
      }
    }
  },

  "default_agent": "compliance",
  "share": "disabled",
  "autoupdate": false,

  "permission": {
    "bash": "deny",
    "external_directory": "deny",
    "edit": "deny",
    "webfetch": "allow"
  },

  "agent": {
    "compliance": {
      "description": "Primary reporting assistant. Interviews the user, requests source documents, drafts the report as a Markdown file, and fact-checks the data.",
      "mode": "primary",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.2,
      "prompt": "{file:./prompts/compliance.md}",
      "permission": {
        "read": "allow",
        "edit": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "bash": "deny",
        "external_directory": {
          "**": "deny",
          "/config/.opencode/skills/**": "allow"
        },
        "webfetch": "allow",
        "websearch": "allow",
        "question": "deny",
        "roadmap_mark_done": "deny",
        "roadmap_mark_undone": "deny",
        "roadmap_status": "deny",
        "skill": {
          "*": "deny",
          "csrd-esrs": "allow",
          "esg-reporting": "allow"
        },
        "task": {
          "*": "deny",
          "fact-checker": "allow"
        }
      }
    },

    "roadmap-sync": {
      "description": "Internal subagent that updates roadmap checklist progress after each main turn. It only calls roadmap MCP tools and never edits files or talks to the user.",
      "mode": "subagent",
      "temperature": 0,
      "prompt": "{file:./prompts/roadmap-sync.md}",
      "permission": {
        "read": "allow",
        "glob": "deny",
        "grep": "deny",
        "list": "deny",
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "question": "deny",
        "skill": { "*": "deny" },
        "task": { "*": "deny" },
        "roadmap_mark_done": "allow",
        "roadmap_mark_undone": "allow",
        "roadmap_status": "allow"
      }
    },

    "fact-checker": {
      "description": "Read-only subagent that verifies figures, claims, and regulatory references against the source documents and the web. Returns a list of confirmed/uncertain/contradicted findings. Never edits files.",
      "mode": "subagent",
      "model": "opencode-go/deepseek-v4-flash",
      "temperature": 0.1,
      "prompt": "{file:./prompts/fact-checker.md}",
      "permission": {
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "edit": "deny",
        "bash": "deny",
        "external_directory": "deny",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "deny",
        "skill": { "*": "deny" },
        "task": { "*": "deny" }
      }
    }
  },

  "mcp": {
    "workspace": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/workspace/index.mjs"],
      "enabled": true
    },
    "roadmap": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/roadmap/index.mjs"],
      "enabled": true
    },
    "time": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/time/index.mjs"],
      "enabled": true
    },
    "fact-check": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/fact-check/index.mjs"],
      "enabled": true,
      "environment": {
        "FACTCHECK_API_KEY": "{env:FACTCHECK_API_KEY}"
      },
      "timeout": 30000
    },
    "doc-ingest": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/doc-ingest/index.mjs"],
      "enabled": false,
      "timeout": 30000
    },
    "doc-generate": {
      "type": "local",
      "command": ["bun", "run", "/config/mcp/doc-generate/index.mjs"],
      "enabled": false,
      "timeout": 30000
    }
  }
}
