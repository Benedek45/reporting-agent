# Copy to .env and fill in. .env is gitignored.

# OpenCode Zen "opencode-go" gateway API key (provider id: opencode-go).
# Get one at https://opencode.ai/auth
OPENCODE_GO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL of the headless `opencode serve` instance.
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Root dir for per-session workspaces (keep OUTSIDE this repo).
# In Docker this is overridden to /workspaces (the shared volume).
WORKSPACES_ROOT=../reporting-agent-workspaces

# Internal document-converter service (MarkItDown). Docker compose sets this to
# http://converter:8000 automatically; this value is for host dev only.
CONVERTER_URL=http://127.0.0.1:8000

# Max bytes of a single file the "Load full file into context" button will inject
# into the chat. Larger files: the agent reads them on demand instead.
MAX_CONTEXT_FILE_BYTES=200000

# Context management: two MIT plugins are auto-loaded from .opencode/plugins/
# (context-manager.js + report-compaction.js). No extra config required.

# Tavily Search API key for the fact-check MCP server (mcp/fact-check/index.mjs).
# Get one at https://tavily.com — the free tier covers development use.
# This value reaches ONLY the opencode container via env_file; the app container
# never sees it. If unset, the fact-check tool returns NEEDS_CONFIG and the agent
# falls back to manual web search.
FACTCHECK_API_KEY=
