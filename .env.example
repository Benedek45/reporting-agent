# Copy to .env and fill in. .env is gitignored.

# OpenCode Zen "opencode-go" gateway API key (provider id: opencode-go).
# Get one at https://opencode.ai/auth
OPENCODE_GO_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# URL of the headless `opencode serve` instance.
OPENCODE_SERVER_URL=http://127.0.0.1:4096

# Root dir for per-session workspaces (keep OUTSIDE this repo).
WORKSPACES_ROOT=../reporting-agent-workspaces
